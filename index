<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Mr. JoA - Master of Flow</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;700;900&display=swap" rel="stylesheet">
    <style>
        :root {
            --brand-orange: #FF6B00;
            --brand-black: #0A0A0A;
        }
        body {
            font-family: 'Inter', sans-serif;
            background-color: var(--brand-black);
            color: white;
            overflow-x: hidden;
        }

        /* Hiệu ứng đường dòng chảy (Flow background) mô phỏng ảnh nền */
        .flow-bg {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            z-index: -1;
            opacity: 0.4;
            background: radial-gradient(circle at 20% 30%, rgba(255, 107, 0, 0.15) 0%, transparent 50%);
        }

        .wave-container {
            position: absolute;
            bottom: 0;
            right: 0;
            width: 80%;
            height: 60%;
            pointer-events: none;
        }

        .wave {
            position: absolute;
            width: 200%;
            height: 100%;
            background: transparent;
            border-top: 1px solid rgba(255, 107, 0, 0.3);
            border-radius: 40%;
            animation: flow 20s linear infinite;
        }

        @keyframes flow {
            from { transform: translateX(0) rotate(0deg); }
            to { transform: translateX(-50%) rotate(5deg); }
        }

        .orange-text { color: var(--brand-orange); }
        .orange-bg { background-color: var(--brand-orange); }
        .border-orange { border-color: var(--brand-orange); }

        .glass-card {
            background: rgba(255, 255, 255, 0.03);
            backdrop-filter: blur(10px);
            border: 1px solid rgba(255, 255, 255, 0.1);
            transition: all 0.3s ease;
        }
        .glass-card:hover {
            border-color: var(--brand-orange);
            transform: translateY(-5px);
        }

        .btn-primary {
            background-color: var(--brand-orange);
            color: white;
            padding: 0.75rem 2rem;
            border-radius: 9999px;
            font-weight: bold;
            transition: all 0.3s ease;
            display: inline-block;
        }
        .btn-primary:hover {
            box-shadow: 0 0 20px rgba(255, 107, 0, 0.5);
            transform: scale(1.05);
        }

        .logo-container {
            display: flex;
            align-items: center;
            gap: 10px;
        }

        .logo-box {
            width: 45px;
            height: 45px;
            background: var(--brand-black);
            border: 3px solid white;
            border-radius: 12px;
            display: flex;
            align-items: center;
            justify-content: center;
            position: relative;
            overflow: hidden;
        }

        .logo-j {
            color: var(--brand-orange);
            font-weight: 900;
            font-size: 24px;
            z-index: 2;
        }
    </style>
</head>
<body>

    <div class="flow-bg">
        <div class="wave-container" id="waves">
            <!-- Sẽ được tạo bằng JS để có nhiều đường line -->
        </div>
    </div>

    <!-- Navigation -->
    <nav class="fixed w-full z-50 px-6 py-4 flex justify-between items-center bg-black/50 backdrop-blur-md">
        <div class="flex items-center gap-3">
            <div class="logo-box">
                <span class="logo-j">J</span>
                <div class="absolute inset-0 bg-white/10"></div>
            </div>
            <div class="leading-tight">
                <div class="font-black text-xl tracking-tighter">Mr. JoA</div>
            </div>
        </div>
        <div class="hidden md:flex gap-8 font-medium uppercase text-sm tracking-widest">
            <a href="#about" class="hover:text-[#FF6B00] transition">Về tôi</a>
            <a href="#projects" class="hover:text-[#FF6B00] transition">Dự án</a>
            <a href="#contact" class="hover:text-[#FF6B00] transition">Liên hệ</a>
        </div>
        <a href="#contact" class="text-sm font-bold border-2 border-orange-500 px-4 py-2 rounded-full hover:bg-orange-600 transition">HỢP TÁC</a>
    </nav>

    <!-- Hero Section -->
    <section class="min-h-screen flex flex-col justify-center items-start px-6 md:px-24 relative overflow-hidden">
        <div class="max-w-4xl z-10">
            <h2 class="text-[#FF6B00] font-bold tracking-[0.3em] mb-4 uppercase">Jack of All Trades</h2>
            <h1 class="text-6xl md:text-9xl font-black mb-6 leading-none">
                MASTER <br> OF <span class="orange-text">FLOW.</span>
            </h1>
            <p class="text-gray-400 text-lg md:text-xl max-w-xl mb-10 leading-relaxed">
                Tối ưu hóa quy trình, khơi nguồn sáng tạo và định hình dòng chảy công việc cho các dự án kỹ thuật số hiện đại.
            </p>
            <div class="flex gap-4">
                <a href="#projects" class="btn-primary">Xem dự án</a>
                <a href="#about" class="px-8 py-3 rounded-full border border-white/20 hover:bg-white/10 transition">Tìm hiểu thêm</a>
            </div>
        </div>
    </section>

    <!-- About Section -->
    <section id="about" class="py-24 px-6 md:px-24 bg-white/5">
        <div class="grid md:grid-cols-2 gap-16 items-center">
            <div class="relative">
                <div class="aspect-square rounded-2xl overflow-hidden border-2 border-orange-500/30">
                    <img src="https://images.unsplash.com/photo-1507003211169-0a1dd7228f2d?q=80&w=1000&auto=format&fit=crop" alt="Profile" class="w-full h-full object-cover grayscale hover:grayscale-0 transition duration-700">
                </div>
                <div class="absolute -bottom-6 -right-6 w-32 h-32 orange-bg rounded-2xl -z-10"></div>
            </div>
            <div>
                <h3 class="text-4xl font-black mb-6">Xây dựng <span class="orange-text">Hệ sinh thái</span> hiệu quả</h3>
                <p class="text-gray-400 mb-6 italic">"Không chỉ là làm việc, mà là làm cho công việc vận hành mượt mà nhất có thể."</p>
                <div class="space-y-4">
                    <div class="flex items-center gap-4">
                        <div class="w-12 h-[2px] orange-bg"></div>
                        <span>Quản lý dự án Agile & Scrum</span>
                    </div>
                    <div class="flex items-center gap-4">
                        <div class="w-12 h-[2px] orange-bg"></div>
                        <span>Thiết kế trải nghiệm người dùng (UX)</span>
                    </div>
                    <div class="flex items-center gap-4">
                        <div class="w-12 h-[2px] orange-bg"></div>
                        <span>Tự động hóa quy trình doanh nghiệp</span>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- Services / Projects -->
    <section id="projects" class="py-24 px-6 md:px-24">
        <div class="text-center mb-16">
            <h3 class="text-5xl font-black mb-4">DỊCH VỤ <span class="orange-text">&</span> DỰ ÁN</h3>
            <p class="text-gray-500">Những giải pháp tối ưu dòng chảy cho khách hàng toàn cầu</p>
        </div>
        <div class="grid md:grid-cols-3 gap-8">
            <div class="glass-card p-8 rounded-2xl">
                <div class="text-4xl mb-6">⚡</div>
                <h4 class="text-xl font-bold mb-4">Workflow Automation</h4>
                <p class="text-gray-400">Tự động hóa các tác vụ lặp đi lặp lại để đội ngũ tập trung vào giá trị cốt lõi.</p>
            </div>
            <div class="glass-card p-8 rounded-2xl border-t-4 border-t-[#FF6B00]">
                <div class="text-4xl mb-6">🎨</div>
                <h4 class="text-xl font-bold mb-4">Digital Strategy</h4>
                <p class="text-gray-400">Chiến lược phát triển sản phẩm kỹ thuật số từ ý tưởng đến khi ra mắt thị trường.</p>
            </div>
            <div class="glass-card p-8 rounded-2xl">
                <div class="text-4xl mb-6">🚀</div>
                <h4 class="text-xl font-bold mb-4">Performance Optimization</h4>
                <p class="text-gray-400">Tối ưu hóa hiệu năng hệ thống và quy trình làm việc của doanh nghiệp.</p>
            </div>
        </div>
    </section>

    <!-- Contact Section -->
    <section id="contact" class="py-24 px-6 md:px-24">
        <div class="orange-bg p-12 rounded-[3rem] text-black flex flex-col md:flex-row justify-between items-center gap-8">
            <div>
                <h3 class="text-4xl md:text-6xl font-black mb-4">Bắt đầu dòng chảy mới?</h3>
                <p class="text-black/70 font-medium">Hãy cùng thảo luận về cách chúng ta có thể làm cho dự án của bạn mượt mà hơn.</p>
            </div>
            <a href="mailto:hello@mrjoa.com" class="bg-black text-white px-12 py-5 rounded-full font-bold text-xl hover:scale-110 transition">LIÊN HỆ NGAY</a>
        </div>
    </section>

    <footer class="py-12 text-center text-gray-600 text-sm">
        <p>© 2024 Mr. JoA. Jack of All, Master of Flow.</p>
    </footer>

    <script>
        // Tạo các đường line uốn lượn (Waves) giống trong ảnh nền
        const container = document.getElementById('waves');
        const waveCount = 15;

        for (let i = 0; i < waveCount; i++) {
            const wave = document.createElement('div');
            wave.className = 'wave';
            
            // Randomize vị trí và độ trễ để tạo cảm giác tự nhiên
            const bottomPos = i * 15;
            const opacity = 1 - (i / waveCount);
            const delay = i * 0.5;
            
            wave.style.bottom = `${bottomPos}px`;
            wave.style.opacity = (opacity * 0.2).toString();
            wave.style.animationDelay = `-${delay}s`;
            wave.style.borderTopColor = `rgba(255, 107, 0, ${opacity})`;
            
            container.appendChild(wave);
        }

        // Smooth scroll
        document.querySelectorAll('a[href^="#"]').forEach(anchor => {
            anchor.addEventListener('click', function (e) {
                e.preventDefault();
                document.querySelector(this.getAttribute('href')).scrollIntoView({
                    behavior: 'smooth'
                });
            });
        });
    </script>
</body>
</html>
